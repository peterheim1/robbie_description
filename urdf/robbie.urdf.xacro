<?xml version="1.0"?>


<robot name="robbie" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- === Args & Globals =========================================================== -->
  <xacro:arg name="use_nominal_extrinsics" default="false"/>
  <xacro:arg name="add_plug"               default="false"/>
  <xacro:arg name="use_mesh"               default="true"/>

  <xacro:property name="M_PI"    value="3.1415926535897931"/>
  <xacro:include  filename="$(find omni_bot2)/urdf/hardware.xacro"/>
  <xacro:include  filename="$(find omni_bot2)/urdf/materials.xacro"/>
  <xacro:include filename="$(find robbie_description)/urdf/robbie_ros2_control.xacro" />

  <!-- Example scale property -->
  <xacro:property name="M_SCALE" value="0.001"/>

  <!-- === Arm Segment Lengths ====================================================== -->
  <xacro:property name="link1_length"  value="0.03"/>
  <xacro:property name="link2_length"  value="0.03"/>
  <xacro:property name="link3_length"  value="0.07"/>
  <xacro:property name="link4_length"  value="0.1"/>
  <xacro:property name="link5_length"  value="0.03"/>
  <xacro:property name="link6_length"  value="0.05"/>
  <xacro:property name="joint_limit"   value="${pi / 2}"/>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>

  

  <!-- === Base ===================================================================== -->
   <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://robbie_description/meshes/omni_base_v2.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
      <xacro:yellow/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robbie_description/meshes/omni_base_v2.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
    </collision>
  </link>

  <!-- === Sensors ================================================================== -->
  <link name="scanner_link">
    <visual>
      <geometry>
        <mesh filename="package://robbie_description/meshes/X4.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
      <xacro:grey2/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robbie_description/meshes/X4.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
    </collision>
  </link>

  <link name="rear_camera_link">
    <visual>
    <origin rpy="1.57 0 1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/d435.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
      <xacro:grey1/>
    </visual>
    <collision>
    <origin rpy="1.57 0 1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/d435.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
    </collision>
    
  </link>

  <link name="oak"/>

  <!-- === Torso ==================================================================== -->
  <link name="torso_link">
    <visual>
      <origin rpy="0 0 -1.57" xyz="0 0 0."/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/robbie_torso.stl" scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
      <xacro:yellow/>
    </visual>
    <collision>
      <origin rpy="0 0 -1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/robbie_torso.stl" scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
    </collision>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="torso_link"/>
    <origin xyz="0.0 0 0.930" rpy="0 0 0"/>
  </joint>

  <joint name="base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

  <joint name="scanner_link" type="fixed">
    <parent link="base_link"/>
    <child  link="scanner_link"/>
    <origin xyz="0.15 0 0.32" rpy="0 0 0"/>
  </joint>

  <joint name="oak" type="fixed">
    <parent link="head_box"/>
    <child  link="oak"/>
    <origin xyz="0.025 0 0.24" rpy="0 0 0"/>
  </joint>

  <joint name="rear_camera_link_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="rear_camera_link"/>
    <origin xyz="-0.10 0 0.45" rpy="0 0 3.14"/>
  </joint>

  <!-- === Head Pan/Tilt ============================================================= -->
  <joint name="head_pan_joint" type="revolute">
    <parent link="torso_link"/>
    <child  link="head_pan"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit lower="-${joint_limit}" upper="${joint_limit}" effort="1" velocity="1.0"/>
  </joint>

  <link name="head_pan">
    <visual>
      <geometry>
        <mesh filename="package://robbie_description/meshes/neck_assy.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
      <xacro:yellow/>
    </visual>
    <collision>
      <origin rpy="0 0 -1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/neck_assy.stl"
              scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
    </collision>
  </link>

  <joint name="head_tilt_joint" type="revolute">
    <parent link="head_pan"/>
    <child  link="head_tilt"/>
    <origin xyz="0 0 0.155" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit lower="-${joint_limit}" upper="${joint_limit}" effort="1" velocity="1.0"/>
  </joint>

  <link name="head_tilt"/>

  <joint name="head_box_joint" type="fixed">
    <parent link="head_tilt"/>
    <child  link="head_box"/>
    <origin xyz="0 0 -0.16" rpy="0 0 0"/>
  </joint>
  
  <link name="head_box">
    <visual>
      <origin rpy="0 0 1.57" xyz="0 0 0."/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/robbie_head.stl" scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
      <xacro:yellow/>
    </visual>
    <collision>
      <origin rpy="0 0 1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robbie_description/meshes/robbie_head.stl" scale="${M_SCALE} ${M_SCALE} ${M_SCALE}"/>
      </geometry>
    </collision>
  </link>

 

  <!-- === 6-DOF Arm Macro =========================================================== -->
  <xacro:macro name="arm" params="prefix side x_offset">

    <!-- Joint 0: Shoulder Pitch -->
    <joint name="${prefix}joint_0" type="revolute">
      <parent link="torso_link"/>
      <child  link="${prefix}link_1"/>
      <origin xyz="0 ${0.14 if side == 'left' else -0.14} -0.03" rpy="0 1.5708 0"/>
      <axis   xyz="0 1 0"/>
      <limit lower="-${joint_limit}" upper="1.50" effort="1" velocity="1.0"/>
    </joint>

    <link name="${prefix}link_1">
      <visual>
        <geometry><cylinder length="${link1_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
        <material name="red"/>
      </visual>
      <collision>
       <geometry><cylinder length="${link1_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
        <material name="red"/>
    </collision>
    </link>

    <!-- Joint 1: Shoulder yaw -->
    <joint name="${prefix}joint_1" type="revolute">
      <parent link="${prefix}link_1"/>
      <child  link="${prefix}link_2"/>
      <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
      <axis   xyz="1 0 0"/>
      <limit lower="${-1.57 if side == 'left' else -0.3}" upper="${0.3 if side == 'left' else 1.57}" effort="1" velocity="1.0"/>
    </joint>

    <link name="${prefix}link_2">
      <visual>
        <geometry><cylinder length="${link2_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
      </visual>
      <collision>
       <geometry><cylinder length="${link2_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
    </collision>
    </link>

    <!-- Joint 2: Shoulder roll -->
    <joint name="${prefix}joint_2" type="revolute">
      <parent link="${prefix}link_2"/>
      <child  link="${prefix}link_3"/>
      <origin xyz="0 0 ${link2_length}" rpy="0 0 0"/>
      <axis   xyz="0 0 1"/>
      <limit lower="-2.96" upper="2.96" effort="1" velocity="1.0"/>
    </joint>

    <link name="${prefix}link_3">
      <visual>
        <geometry><cylinder length="${link3_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
      </visual>
      <collision>
       <geometry><cylinder length="${link3_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
    </collision>
    </link>

    <!-- Joint 3: Elbow Pitch -->
    <joint name="${prefix}joint_3" type="revolute">
      <parent link="${prefix}link_3"/>
      <child  link="${prefix}link_4"/>
      <origin xyz="0 0 ${link3_length}" rpy="0 0 0"/>
      <axis   xyz="0 1 0"/>
      <limit lower="-1.80" upper="1.8" effort="1" velocity="1.0"/>
    </joint>

    <link name="${prefix}link_4">
      <visual>
        <geometry><cylinder length="${link4_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
      </visual>
      <collision>
       <geometry><cylinder length="${link4_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
    </collision>
    </link>

    <!-- Joint 4: Wrist Yaw -->
    <joint name="${prefix}joint_4" type="revolute">
      <parent link="${prefix}link_4"/>
      <child  link="${prefix}link_5"/>
      <origin xyz="0 0 ${link4_length}" rpy="0 0 0"/>
      <axis   xyz="1 0 0"/>
      <limit lower="-${joint_limit}" upper="${joint_limit}" effort="1" velocity="1.0"/>
    </joint>

    <link name="${prefix}link_5">
      <visual>
        <geometry><cylinder length="${link5_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
      </visual>
      <collision>
       <geometry><cylinder length="${link5_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
    </collision>
    </link>

    <!-- Joint 5: Wrist pitch -->
    <joint name="${prefix}joint_5" type="revolute">
      <parent link="${prefix}link_5"/>
      <child  link="${prefix}link_6"/>
      <origin xyz="0 0 ${link5_length}" rpy="0 0 0"/>
      <axis   xyz="0 1 0"/>
      <limit lower="-${joint_limit}" upper="${joint_limit}" effort="1" velocity="1.0"/>
    </joint>

    <link name="${prefix}link_6">
      <visual>
        <geometry><cylinder length="${link6_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link6_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
      </visual>
      <collision>
       <geometry><cylinder length="${link6_length}" radius="0.02"/></geometry>
        <origin xyz="0 0 ${link6_length/2}" rpy="0 0 0"/>
        <material name="blue"/>
    </collision>
    </link>

    <!-- End Effector -->
    <joint name="${prefix}_ee_fixed_joint" type="fixed">
      <parent link="${prefix}Fixed_Jaw"/>
      <child  link="${prefix}end_effector"/>
      <origin xyz="0 0 0" rpy="0 3.14 1.57"/>
    </joint>

    <link name="${prefix}end_effector"/>
    
    <!-- ____________________________________ gripper_______________________________________-->

   <!-- Joint 6: Wrist pitch -->
  
  <link
    name="${prefix}Wrist_Pitch_Roll">
    <inertial>
      <origin
        xyz="-0.00852653127372418 -0.0352278997897927 -2.34622481569413E-05"
        rpy="0 0 0" />
      <mass
        value="0.066132067097723" />
      <inertia
        ixx="1.95717492443445E-05"
        ixy="-6.62714374412293E-07"
        ixz="5.20089016442066E-09"
        iyy="2.38028417569933E-05"
        iyz="4.09549055863776E-08"
        izz="3.4540143384536E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robbie_description/meshes/Wrist_Pitch_Roll.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robbie_description/meshes/Wrist_Pitch_Roll.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="${prefix}wrist_link_6"
    type="fixed">
    <origin
      xyz="0 0. 0.05"
      rpy="-1.57 0 -1.57" />
    <parent
      link="${prefix}link_6" />
    <child
      link="${prefix}Wrist_Pitch_Roll" />
    <axis
      xyz="0 1 0" />
  </joint>
  
  <link
    name="${prefix}Fixed_Jaw">
    <inertial>
      <origin
        xyz="0.00552376906426563 -0.0280167153359021 0.000483582592841092"
        rpy="0 0 0" />
      <mass
        value="0.0929859131176897" />
      <inertia
        ixx="4.3328249304211E-05"
        ixy="7.09654328670947E-06"
        ixz="5.99838530879484E-07"
        iyy="3.04451747368212E-05"
        iyz="-1.58743247545413E-07"
        izz="5.02460913506734E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robbie_description/meshes/Fixed_Jaw.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robbie_description/meshes/Fixed_Jaw.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="${prefix}joint_6"
    type="continuous">
    <origin
      xyz="0 -0.0601 0"
      rpy="0 -1.57  0" />
    <parent
      link="${prefix}Wrist_Pitch_Roll" />
    <child
      link="${prefix}Fixed_Jaw" />
    <axis
      xyz="0 1 0" />
      <limit lower="-2.96" upper="2.96" effort="1" velocity="1.0"/>
  </joint>
  <link
    name="${prefix}Moving Jaw">
    <inertial>
      <origin
        xyz="-0.00161744605468241 -0.0303472584046471 0.000449645961853651"
        rpy="0 0 0" />
      <mass
        value="0.0202443794940372" />
      <inertia
        ixx="1.10911325081525E-05"
        ixy="-5.35076503033314E-07"
        ixz="-9.46105662101403E-09"
        iyy="3.03576451001973E-06"
        iyz="-1.71146075110632E-07"
        izz="8.9916083370498E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robbie_description/meshes/Moving Jaw.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://robbie_description/meshes/Moving Jaw.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="${prefix}gripper"
    type="revolute">
    <origin
      xyz="-0.0202 -0.0244 0"
      rpy="3.1416 0 3.1416" />
    <parent
      link="${prefix}Fixed_Jaw" />
    <child
      link="${prefix}Moving Jaw" />
    <axis
      xyz="0 0 1" />
      <limit lower="-0.26" upper="${joint_limit}" effort="1" velocity="1.0"/>
  </joint>

  </xacro:macro>

  <!-- === Left and Right Arms ======================================================= -->
  <xacro:arm prefix="left_"  side="left"  x_offset="0.0"/>
  <xacro:arm prefix="right_" side="right" x_offset="0.0"/>
  


</robot>

